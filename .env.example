# Server-side admin credentials for Vercel deployment
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth for admin login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://cvht.vercel.app/api/auth/google/callback

# Comma-separated list of allowed admin email addresses
ADMIN_EMAILS=admin@example.com

# Secure cookie signing secret
SESSION_SECRET=

# Optional local overrides for frontend provider defaults
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GROQ_MODEL=llama-3.1-8b-instant
